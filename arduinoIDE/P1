Eloquent::ML::Port::RandomForest model;


/* ===============================
   BSM STRUCT
================================= */

typedef struct {
  float lat;
  float lon;
  float speed;
  float accel;
  bool  brake;
} BSM;


/* ===============================
   DISTANCE
================================= */

float distanceMeters(float lat1,float lon1,float lat2,float lon2){
    float dLat = (lat2-lat1)*111139;
    float dLon = (lon2-lon1)*111139;
    return sqrt(dLat*dLat + dLon*dLon);
}


/* ===============================
   TTC
================================= */

float computeTTC(float dist,float s1,float s2){
    float rel = abs(s1-s2);
    if(rel < 0.1) return 999;
    return dist/rel;
}


/* ===============================
   COLLISION ANALYSIS
================================= */

void analyze(BSM a, BSM b){

    float x[3];

    x[0] = a.speed;
    x[1] = a.accel;
    x[2] = a.brake ? 1 : 0;

    int pred = model.predict(x);

    float dist = distanceMeters(a.lat,a.lon,b.lat,b.lon);
    float ttc  = computeTTC(dist,a.speed,b.speed);

    float risk = pred ? 0.92 : 0.08;

    Serial.println();
    Serial.println("==============================");
    Serial.println("      V2V COLLISION ANALYSIS");
    Serial.println("==============================");

    Serial.print("Risk Score   : ");
    Serial.println(risk,2);

    Serial.print("Distance (m) : ");
    Serial.println(dist,2);

    Serial.print("TTC (sec)    : ");
    Serial.println(ttc,2);

    Serial.println("------------------------------");

    if (ttc < 2)
        Serial.println("STATUS       : CRITICAL COLLISION ALERT");
    else if (ttc < 4)
        Serial.println("STATUS       : WARNING");
    else
        Serial.println("STATUS       : SAFE");

    Serial.println("==============================");
}


