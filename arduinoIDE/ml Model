#include <Arduino.h>

/*
   TinyML Decision Tree Model
   Input: [speed, rain, badRoad, dark]
   Output: 0 = LOW, 1 = MEDIUM, 2 = HIGH
*/

class DecisionTree {
  public:
    int predict(float *x) {

      if (x[0] <= 70.5) {
        if (x[2] <= 0.5) {
          if (x[0] <= 60.5) {
            return 0;
          }
          else {
            if (x[3] <= 0.5) return 0;
            else return 1;
          }
        }
        else {
          return 1;
        }
      }

      else {
        if (x[1] <= 0.5) {
          if (x[0] <= 95.5) {
            if (x[3] <= 0.5) return 0;
            else return 1;
          }
          else {
            return 2;
          }
        }
        else {
          return 2;
        }
      }

    }
};

DecisionTree model;

void setup() {
  Serial.begin(115200);
  delay(1000);
  Serial.println("🚗 V2V Collision Alert System Started");
}

void loop() {

  float input[4];

  // 🔹 CHANGE THESE VALUES (later connect sensors)
  input[0] = ;   // speed (km/h)
  input[1] = 1;     // rain (1 = yes)
  input[2] = 0;     // bad road (1 = yes)
  input[3] = 1;     // dark (1 = night)

  int prediction = model.predict(input);

  String alert;

  if (prediction == 2) {
    alert = "HIGH";
  }
  else if (prediction == 1) {
    alert = "MEDIUM";
  }
  else {
    alert = "LOW";
  }

  Serial.print("Speed: "); Serial.print(input[0]);
  Serial.print(" | Rain: "); Serial.print(input[1]);
  Serial.print(" | Road: "); Serial.print(input[2]);
  Serial.print(" | Dark: "); Serial.print(input[3]);

  Serial.print("  ---> ALERT: ");
  Serial.println(alert);

  Serial.println("--------------------------");

  delay(3000);
}
